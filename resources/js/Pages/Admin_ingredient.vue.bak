                                        class="origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-10"
                                    >
                                        <div class="py-1">
                                            <a
                                                href="#"
                                                @click.prevent="
                                                    filterByStatus('All')
                                                "
                                                class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer"

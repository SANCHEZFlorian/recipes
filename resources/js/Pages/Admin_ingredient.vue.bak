                                    >
                                        <div class="py-1">
                                            <a
                                                href="#"
                                                @click.prevent="
                                                    filterByNutritionalInfo(
                                                        'All',
                                                    )
                                                "
                                                class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer"
                                                >All</a
                                            >
                                            <a
                                                href="#"
                                                @click.prevent="
                                                    filterByNutritionalInfo(
                                                        'Available',
                                                    )
                                                "
                                                class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer"
                                                >Available</a
                                            >
                                            <a
                                                href="#"
                                                @click.prevent="
                                                    filterByNutritionalInfo(
                                                        'Not Available',
                                                    )
                                                "
                                                class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer"
                                                >Not Available</a
                                            >
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Applied Filters -->
                        <div
